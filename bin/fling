#!/usr/bin/env bash
# Stable launcher only; all Fling behavior lives in the Rust executable.
set -euo pipefail
here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -x "$here/fling-rs" ]; then exec "$here/fling-rs" "$@"; fi
root="$(cd "$here/.." && pwd)"
if [ -x "$root/target/debug/fling-rs" ]; then exec "$root/target/debug/fling-rs" "$@"; fi
echo "ERROR: fling-rs binary is missing; build with cargo build or reinstall Fling" >&2
exit 127
